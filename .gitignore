# Secrets / credentials
.env
.access_token

# Market data output
data/

# Personal trading data
positions.json
trade_journal.csv

# Java compiled bytecode (safety net — target/ covers Maven output)
*.class

# Python bytecode (safety net — in case scratch/ scripts are ever run)
__pycache__/
*.pyc

# Java / Maven build output (the Maven Wrapper mvnw/.mvn IS committed)
target/
.mvn/wrapper/maven-wrapper.jar

# IDE-specific files
.vscode/
.idea/
*.iml

# Agent / analysis scratch space (throwaway scripts — never source)
scratch/

# Claude Code local settings (personal permission allowlists + transient auth-code grants)
.claude/settings.json
.claude/settings.local.json
