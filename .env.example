# ─────────────────────────────────────────────────────────────────────────
# Upstox API credentials — TEMPLATE
#
# Setup:
#   1. Copy this file to ".env"   (the real .env is gitignored — never commit it)
#   2. Fill in the values below from your Upstox developer app
#   3. Create / manage your app at: https://account.upstox.com/developer/apps
#
# The .access_token file is generated automatically each day by the login flow
# (src/auth.py or src/get_token.py) — you do NOT create it here.
# ─────────────────────────────────────────────────────────────────────────

# Your Upstox app's API key (UUID-style string)
UPSTOX_API_KEY=your_upstox_api_key_here

# Your Upstox app's API secret
UPSTOX_API_SECRET=your_upstox_api_secret_here

# The redirect URI registered in your Upstox app — must match EXACTLY.
# For local use the loopback default below is fine.
UPSTOX_REDIRECT_URI=https://127.0.0.1
